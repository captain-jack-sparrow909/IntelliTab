{
     "version": "0.2.0",
     "configurations": [
         {
             "name": "Run Extension",
              "type": "extensionHost",
              "request": "launch",
              "runtime": "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code",
              "env": {
                   "PATH": "/Users/jabirkhan/.local/bin:/usr/local/bin:/usr/bin:/bin"
              },
              "args": [
                   "--extensionDevelopmentPath",
                   "${workspaceFolder}",
                   "${workspaceFolder}"
              ],
             "outFiles": [
                  "${workspaceFolder}/out/**/*.js"
             ],
              "preLaunchTask": "npm: compile"
         }
     ]
}
