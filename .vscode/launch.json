{
     "version": "0.2.0",
     "configurations": [
         {
             "name": "Run Extension",
             "type": "extensionHost",
             "request": "launch",
             "runtime": "code",
             "args": [
                  "--extensionDevelopmentPath",
                  "${workspaceFolder}"
             ],
             "outFiles": [
                  "${workspaceFolder}/out/**/*.js"
             ],
             "preLaunchTask": {
                  "type": "shell",
                  "command": "npm",
                  "args": ["run", "compile"],
                  "problemMatcher": ["$tsc"]
             }
         }
     ]
}
