{
  "name": "mlx-code-completion",
  "displayName": "MLX Code Completion",
  "description": "Low-latency AI code completion powered by local MLX models on Apple Silicon",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mlxCompletion.trigger",
        "title": "MLX: Trigger Inline Completion"
      }
    ],
    "configuration": {
      "title": "MLX Code Completion",
      "properties": {
        "mlxCompletion.modelPath": {
          "type": "string",
          "default": "",
          "description": "Path to MLX model dir. Empty = auto (prefers ~/.mlx-models/Qwen2.5-Coder-3B-4bit base FIM model)."
        },
        "mlxCompletion.quantization": {
          "type": "string",
          "enum": ["4bit", "8bit", "BF16"],
          "default": "4bit",
          "description": "Quantization level (only applied if the checkpoint is not already quantized)"
        },
        "mlxCompletion.debounceMs": {
          "type": "number",
          "default": 50,
          "minimum": 35,
          "maximum": 200,
          "description": "Debounce before requesting a completion (35-200ms)."
        },
        "mlxCompletion.maxTokens": {
          "type": "number",
          "default": 32,
          "description": "Max tokens for FIM/mid-line completions (intent uses more, early-stops when complete)."
        },
        "mlxCompletion.contextLinesBefore": {
          "type": "number",
          "default": 60,
          "description": "Upper bound on lines before cursor. Adaptive context uses less for FIM."
        },
        "mlxCompletion.contextLinesAfter": {
          "type": "number",
          "default": 15,
          "description": "Upper bound on lines after cursor."
        },
        "mlxCompletion.temperature": {
          "type": "number",
          "default": 0.0,
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Generation temperature (0.0 = deterministic)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test:bench": "python3 tests/bench_completion.py",
    "test:unit": "python3 tests/bench_completion.py --unit-only"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0"
  }
}
